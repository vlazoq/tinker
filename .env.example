# ============================================================================
# Tinker — Environment Variable Reference
# ============================================================================
#
# Copy this file to .env and edit as needed:
#
#   cp .env.example .env
#
# Variables with values shown are defaults. Variables prefixed with # and an
# empty value (e.g. "# VAR=") are optional — uncomment only if you need them.
#
# ============================================================================


# ─── LLM Configuration ─────────────────────────────────────────────────────
# Primary Ollama server (7B-class model for Architect + Synthesizer roles)
# and secondary server (2-3B model for the Critic/Judge role).

TINKER_SERVER_URL=http://localhost:11434
TINKER_SERVER_MODEL=qwen3:7b
TINKER_SERVER_CTX=8192
TINKER_SERVER_MAX_OUT=2048
TINKER_SERVER_TIMEOUT=120
TINKER_SERVER_KEEP_ALIVE=10m
# TINKER_SERVER_FALLBACK_MODEL=          # model to try when the primary is unavailable

TINKER_SECONDARY_MODEL=phi3:mini
TINKER_SECONDARY_URL=http://secondary:11434
TINKER_SECONDARY_CTX=4096
TINKER_SECONDARY_MAX_OUT=1024
TINKER_SECONDARY_TIMEOUT=60
TINKER_SECONDARY_KEEP_ALIVE=10m
# TINKER_SECONDARY_FALLBACK_MODEL=       # fallback for the secondary/judge model

TINKER_LLM_BACKEND=ollama
TINKER_TEMPERATURE=0.7


# ─── Orchestrator ───────────────────────────────────────────────────────────
# Controls the Micro -> Meso -> Macro reasoning loops, checkpointing,
# and human-in-the-loop confirmation gates.

TINKER_MESO_TRIGGER=5                    # micro iterations before a meso synthesis
TINKER_MACRO_INTERVAL=14400              # seconds between macro cycles (default: 4 hours)
TINKER_ARCHITECT_TIMEOUT=120             # per-call timeout for the architect agent (seconds)
TINKER_CRITIC_TIMEOUT=60                 # per-call timeout for the critic agent (seconds)
TINKER_STATE_PATH=./tinker_state.json    # orchestrator state snapshot (read by dashboard)
TINKER_CHECKPOINT_ENABLED=true           # save/resume in-progress loop state on crash
TINKER_CHECKPOINT_PATH=./tinker_checkpoint.json
# TINKER_CONFIRM_BEFORE=                 # comma-separated actions needing human approval (e.g. git_push,artifact_delete)
TINKER_CONFIRM_TIMEOUT=300               # seconds to wait for human confirmation before auto-approve
TINKER_INSTRUCTIONS_PATH=./TINKER.md     # project instructions injected into the Architect prompt


# ─── Storage Paths ──────────────────────────────────────────────────────────
# Databases and caches. Defaults to SQLite; set DB_BACKEND and POSTGRES_DSN
# for PostgreSQL.

TINKER_WORKSPACE=./tinker_workspace
TINKER_REDIS_URL=redis://localhost:6379
TINKER_REDIS_TTL=3600
TINKER_DUCKDB_PATH=tinker_session.duckdb
TINKER_CHROMA_PATH=./chroma_db
TINKER_SQLITE_PATH=tinker_tasks.sqlite
TINKER_TASK_DB=tinker_tasks_engine.sqlite
TINKER_DB_BACKEND=sqlite
# TINKER_POSTGRES_DSN=                   # e.g. postgresql://user:pass@host:5432/tinker
TINKER_AUDIT_LOG_PATH=tinker_audit.sqlite
TINKER_DLQ_PATH=tinker_dlq.sqlite


# ─── Directories ────────────────────────────────────────────────────────────
# Output directories for artifacts, diagrams, backups, and control files.

# TINKER_BASE_DIR=                       # override project root auto-detection
TINKER_ARTIFACT_DIR=./tinker_artifacts
TINKER_ARTIFACTS_DIR=./tinker_artifacts
TINKER_DIAGRAM_DIR=./tinker_diagrams
TINKER_BACKUP_DIR=./tinker_backups
TINKER_BACKUP_RETENTION_DAYS=7
ARTIFACT_OUTPUT_DIR=./artifacts
DIAGRAM_OUTPUT_DIR=./artifacts/diagrams
TINKER_CONFIRM_DIR=./tinker_confirmations
TINKER_CONTROL_DIR=./tinker_control


# ─── Web UI ─────────────────────────────────────────────────────────────────
# FastAPI dashboard, health endpoint, and optional Gradio/Streamlit ports.

TINKER_WEBUI_PORT=8082
TINKER_WEBUI_RATE_PER_SEC=2.0            # requests per second per IP
TINKER_WEBUI_RATE_BURST=30.0             # burst bucket size
# TINKER_WEBUI_CONFIG=                   # path to JSON config override for the web UI
TINKER_HEALTH_ENABLED=true
TINKER_HEALTH_PORT=8080
TINKER_HEALTH_URL=http://localhost:8081
TINKER_GRADIO_PORT=7860
TINKER_STREAMLIT_PORT=8501


# ─── Logging & Observability ───────────────────────────────────────────────
# Log format, Prometheus metrics, and OpenTelemetry tracing.

TINKER_LOG_LEVEL=INFO
TINKER_JSON_LOGS=false                   # true for JSON lines (useful for Loki/ELK)
TINKER_METRICS_ENABLED=true
TINKER_METRICS_PORT=9090
# TINKER_OTLP_ENDPOINT=                  # e.g. http://localhost:4317
# TINKER_OTLP_HEADERS=                   # comma-separated key=value pairs
TINKER_OTLP_SERVICE_NAME=tinker
TINKER_TRACER_WINDOW=100                 # sliding window size for trace sampling


# ─── Security ───────────────────────────────────────────────────────────────
# Encryption key for artifacts at rest and optional secrets-manager backends
# (file-based or HashiCorp Vault).

# TINKER_ARTIFACT_KEY=                   # Fernet key for encrypting stored artifacts
# TINKER_SECRET_BACKEND=                 # "file", "vault", or "env" (default)
# TINKER_SECRETS_FILE=                   # path to a JSON/YAML secrets file
# TINKER_VAULT_URL=                      # HashiCorp Vault address
# TINKER_VAULT_TOKEN=                    # Vault authentication token
# VAULT_ADDR=                            # standard Vault env var (alias)
# VAULT_TOKEN=                           # standard Vault env var (alias)


# ─── MCP (Model Context Protocol) ──────────────────────────────────────────
# Expose Tinker as an MCP server so external tools (e.g. Claude Code) can
# connect, and consume tools from upstream MCP servers.

TINKER_MCP_ENABLED=false
TINKER_MCP_SERVER_NAME=tinker
TINKER_MCP_SERVER_PATH=/mcp
TINKER_MCP_SERVER_VERSION=1.0.0
TINKER_MCP_CONNECT_TIMEOUT=10            # seconds to wait when connecting to external MCP servers
TINKER_MCP_RATE_PER_SEC=1.0
TINKER_MCP_RATE_BURST=60.0
# TINKER_MCP_TOKEN=                      # bearer token for MCP authentication
# TINKER_MCP_SERVERS=                    # comma-separated list of upstream MCP server SSE URLs


# ─── Architecture State ────────────────────────────────────────────────────
# Persistent files that store model presets and active configuration.

TINKER_AUTO_GIT=true
TINKER_ACTIVE_PRESET_FILE=./tinker_active_preset.json
TINKER_PRESETS_FILE=./tinker_presets.json
TINKER_MODELS_FILE=./tinker_models.json


# ─── Backpressure ──────────────────────────────────────────────────────────
# Queue-depth thresholds that trigger warnings or pause ingestion.

TINKER_BP_WARN_DEPTH=50                  # log a warning when queue depth exceeds this
TINKER_BP_PAUSE_DEPTH=200                # pause new work when queue depth exceeds this


# ─── Alerts ─────────────────────────────────────────────────────────────────
# Webhook URLs for outbound notifications on errors or milestones.

# TINKER_ALERT_WEBHOOK=                  # generic webhook URL (JSON POST)
# TINKER_SLACK_WEBHOOK=                  # Slack incoming-webhook URL


# ─── Feature Flags ─────────────────────────────────────────────────────────
# Runtime feature toggles hot-reloaded from a JSON file.

# TINKER_FLAGS_FILE=                     # path to a JSON feature-flags file
TINKER_FLAGS_RELOAD_INTERVAL=30          # seconds between flag-file reloads
TINKER_SELF_IMPROVE_ENABLED=false        # allow the engine to modify its own prompts
# TINKER_IMPROVE_BRANCH=                 # git branch for self-improvement commits


# ─── Fritz Agent (VCS / Git Integration) ───────────────────────────────────
# Fritz handles commits, pushes, and PR creation against Git/Gitea/GitHub.

# FRITZ_CONFIG_FILE=                     # path to Fritz YAML/JSON config
FRITZ_DEBUGGER_MODEL=qwen2.5-coder:32b
FRITZ_METRICS_ENABLED=true
FRITZ_METRICS_PORT=9091


# ─── Grub Agent (Code Generation) ──────────────────────────────────────────
# Autonomous coding agent with coder, reviewer, tester, debugger,
# refactorer, and summarizer sub-roles.

GRUB_OLLAMA_URL=http://localhost:11434
GRUB_CODER_MODEL=qwen2.5-coder:32b
GRUB_REVIEWER_MODEL=qwen3:7b
GRUB_TESTER_MODEL=qwen3:7b
GRUB_DEBUGGER_MODEL=qwen2.5-coder:32b
GRUB_REFACTORER_MODEL=qwen2.5-coder:7b
# GRUB_SUMMARIZER_MODEL=                 # defaults to the reviewer model if unset
GRUB_EXEC_MODE=sequential               # "sequential" or "parallel"
GRUB_MAX_ITERATIONS=5                    # max retries per minion before giving up
GRUB_QUALITY_THRESHOLD=0.75             # reviewer score (0.0-1.0) needed to accept output
GRUB_OUTPUT_DIR=./grub_output
GRUB_QUEUE_DB=grub_queue.sqlite
GRUB_ARTIFACTS_DIR=./grub_artifacts
GRUB_QUEUE_WORKERS=2
GRUB_ENABLE_GIT=false                    # auto-commit generated code to git
GRUB_REQUEST_TIMEOUT=120.0               # HTTP timeout for Ollama requests (seconds)
GRUB_CONTEXT_SUMMARIZATION=true          # summarize large inputs instead of truncating
GRUB_CONTEXT_MAX_CHARS=6000              # trigger summarization above this char count
GRUB_CONTEXT_TARGET_CHARS=3000           # target length after summarization
# GRUB_ALLOW_PUSH_TO_MAIN=              # set to "true" to allow direct pushes to main


# ─── Trino (Optional Federated Queries) ────────────────────────────────────
# Connect to a Trino cluster for cross-source SQL queries over session data.

TINKER_TRINO_HOST=localhost
TINKER_TRINO_PORT=8080
TINKER_TRINO_USER=tinker
TINKER_TRINO_CATALOG=memory
TINKER_TRINO_SCHEMA=tinker
TINKER_TRINO_TABLE=session_artifacts


# ─── Azure OpenAI (Optional) ───────────────────────────────────────────────
# Use Azure-hosted OpenAI models instead of or alongside local Ollama.

# AZURE_OPENAI_ENDPOINT=                 # e.g. https://myinstance.openai.azure.com/


# ─── Web Scraper ───────────────────────────────────────────────────────────
# Timeout for the headless scraper used by the web-search tool.

SCRAPER_TIMEOUT_MS=20000


# ─── SearxNG ───────────────────────────────────────────────────────────────
# Local SearxNG instance for privacy-respecting web searches.

TINKER_SEARXNG_URL=http://localhost:8080

# Number of top search results to scrape per research query (default 3).
# Higher values provide broader context but increase latency and load.
# TINKER_RESEARCH_MAX_SCRAPE=3

# Max concurrent parallel research queries via ResearchTeam (default 3).
# Set to 1 to disable parallel research and revert to sequential behaviour.
# TINKER_RESEARCH_CONCURRENCY=3


# ─── Auto-Memory (cross-session learning) ──────────────────────────────────

# Directory for auto-memory persistence files (auto_memory.json, MEMORY.md).
# TINKER_MEMORY_DIR=./tinker_memory

# Critic scores above this threshold trigger "effective pattern" memories.
# TINKER_MEMORY_HIGH_THRESHOLD=0.85

# Critic scores below this threshold trigger "pitfall" memories.
# TINKER_MEMORY_LOW_THRESHOLD=0.4


# ─── Idempotency ───────────────────────────────────────────────────────────
# TTL (in seconds) for idempotency keys that prevent duplicate operations.

TINKER_IDEMPOTENCY_TTL=3600


# ─── Role / Machine ────────────────────────────────────────────────────────
# Tag this instance with a role name for multi-node deployments.

# TINKER_ROLE_MACHINE=                   # e.g. "worker-1" or "orchestrator"
