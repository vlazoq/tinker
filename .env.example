# ──────────────────────────────────────────────────────────────────────────────
# Tinker — Environment Variable Template
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────────────────────────

# ── Ollama — Primary Server (i7-7700 / RTX 3090, runs Qwen3-7B) ───────────────
TINKER_SERVER_URL=http://localhost:11434
TINKER_SERVER_MODEL=qwen3:7b
TINKER_SERVER_CTX=8192
TINKER_SERVER_MAX_OUT=2048
TINKER_SERVER_TIMEOUT=120

# ── Ollama — Secondary Machine (runs Phi-3-mini) ──────────────────────────────
TINKER_SECONDARY_URL=http://secondary:11434
TINKER_SECONDARY_MODEL=phi3:mini
TINKER_SECONDARY_CTX=4096
TINKER_SECONDARY_MAX_OUT=1024
TINKER_SECONDARY_TIMEOUT=60

# Fallback models — used when the primary model is not found in Ollama.
# Leave empty to disable fallback (Tinker will raise ModelNotFoundError instead).
TINKER_SERVER_FALLBACK_MODEL=
TINKER_SECONDARY_FALLBACK_MODEL=

# ── Memory backends ───────────────────────────────────────────────────────────
TINKER_REDIS_URL=redis://localhost:6379
TINKER_DUCKDB_PATH=tinker_session.duckdb
TINKER_CHROMA_PATH=./chroma_db
TINKER_SQLITE_PATH=tinker_tasks.sqlite

# ── Tool Layer ────────────────────────────────────────────────────────────────
# SearXNG self-hosted search (started by docker compose up -d).
# Port 8888 avoids conflict with the orchestrator health endpoint (8081)
# and the default Ollama port (11434).
TINKER_SEARXNG_URL=http://localhost:8888

# ── Artifact / Diagram output dirs ────────────────────────────────────────────
TINKER_ARTIFACT_DIR=./tinker_artifacts
TINKER_DIAGRAM_DIR=./tinker_diagrams

# ── Task Engine ───────────────────────────────────────────────────────────────
TINKER_TASK_DB=tinker_tasks_engine.sqlite

# ── Architecture State Manager ────────────────────────────────────────────────
TINKER_WORKSPACE=./tinker_workspace
TINKER_AUTO_GIT=true

# ── Orchestrator tuning ───────────────────────────────────────────────────────
TINKER_MACRO_INTERVAL=14400   # seconds (4 hours)
TINKER_MESO_TRIGGER=5         # micro loops per subsystem before meso synthesis
TINKER_ARCHITECT_TIMEOUT=120  # seconds
TINKER_CRITIC_TIMEOUT=60      # seconds

# ── Orchestrator state snapshot (used by dashboard) ──────────────────────────
# Written after every micro loop so the web/TUI dashboard can read it.
# Defaults to ./tinker_state.json (relative to the working directory) if unset.
# Windows: keep as a relative path — /tmp does not exist on Windows.
TINKER_STATE_PATH=./tinker_state.json

# ── Logging ───────────────────────────────────────────────────────────────────
TINKER_LOG_LEVEL=INFO

# ── Structured / JSON logging (Phase 2 — observability) ───────────────────────
# Set to true to emit JSON log lines (useful for log aggregators like Loki/ELK)
# Set to false for human-readable text output (default for development)
TINKER_LOG_JSON=false
TINKER_LOG_FILE=                  # path to log file (empty = stdout only)

# ── Health HTTP endpoint (Phase 2 — observability) ────────────────────────────
# Exposes /live, /ready, /health, /status on a lightweight asyncio TCP server.
# Set TINKER_HEALTH_ENABLED=false to disable (e.g. when behind a Kubernetes sidecar).
# Port 8081 is used to avoid conflict with SearXNG which also runs on 8080 by default.
TINKER_HEALTH_ENABLED=true
TINKER_HEALTH_PORT=8081           # port for the health endpoint server

# ── Alerting — Slack / Generic Webhook (Phase 2 — observability) ──────────────
# Leave blank to disable external alerting (logs will still capture events).
TINKER_SLACK_WEBHOOK=             # Slack Incoming Webhook URL
TINKER_ALERT_WEBHOOK=             # Generic webhook URL for custom integrations
TINKER_ALERT_SEVERITY=WARNING     # Minimum severity to send: INFO, WARNING, ERROR, CRITICAL

# ── Dead Letter Queue (Phase 1 — resilience) ──────────────────────────────────
# SQLite file that stores permanently failed operations for later inspection.
TINKER_DLQ_PATH=./tinker_dlq.sqlite

# ── Audit Log (Phase 3 — observability) ───────────────────────────────────────
# SQLite append-only log of all system events for compliance and debugging.
TINKER_AUDIT_LOG_PATH=./tinker_audit.sqlite

# ── Data Lineage Tracker (Phase 4 — observability) ────────────────────────────
# SQLite directed graph of task → artifact derivation relationships.
TINKER_LINEAGE_PATH=./tinker_lineage.sqlite

# ── Backup / Restore (Phase 1 — resilience) ───────────────────────────────────
# Directory where timestamped backup snapshots are stored.
TINKER_BACKUP_DIR=./tinker_backups
# How many days to keep old backups before pruning them.
TINKER_BACKUP_RETENTION_DAYS=7

# ── Secret Manager (Phase 3 — security) ──────────────────────────────────────
# Backend to use for reading secrets: env (default), vault, aws
TINKER_SECRET_BACKEND=env
# HashiCorp Vault URL (only used when TINKER_SECRET_BACKEND=vault)
TINKER_VAULT_URL=http://localhost:8200
TINKER_VAULT_TOKEN=               # Vault token or left empty to use VAULT_TOKEN env var
# AWS region for Secrets Manager (only when TINKER_SECRET_BACKEND=aws)
TINKER_AWS_REGION=us-east-1

# ── Feature Flags (Phase 4 — nice-to-have) ───────────────────────────────────
# JSON file from which feature flags are hot-reloaded every 30 seconds.
# Leave blank to use only environment variable and in-memory overrides.
TINKER_FLAGS_FILE=                # path to feature flags JSON, e.g. ./tinker_flags.json

# Individual feature flag overrides via env vars (prefix: TINKER_FLAG_):
# Each maps to a flag key with the prefix stripped and lowercased.
# Examples:
#   TINKER_FLAG_DISTRIBUTED_LOCK_ENABLED=true    → distributed_lock_enabled
#   TINKER_FLAG_IDEMPOTENCY_ENABLED=true         → idempotency_enabled
#   TINKER_FLAG_RATE_LIMITING_ENABLED=true       → rate_limiting_enabled
#   TINKER_FLAG_CIRCUIT_BREAKERS_ENABLED=true    → circuit_breakers_enabled
#   TINKER_FLAG_AUDIT_LOG_ENABLED=true           → audit_log_enabled
#   TINKER_FLAG_LINEAGE_TRACKING_ENABLED=true    → lineage_tracking_enabled
#   TINKER_FLAG_CAPACITY_PLANNING_ENABLED=true   → capacity_planning_enabled
#   TINKER_FLAG_AB_TESTING_ENABLED=false         → ab_testing_enabled

# ── Capacity Planning (Phase 4 — nice-to-have) ────────────────────────────────
# Alert when daily token usage exceeds this number (0 = no limit)
TINKER_CAPACITY_TOKEN_LIMIT=0
# Alert when disk usage (workspace + artifacts) exceeds this many MB (0 = no limit)
TINKER_CAPACITY_DISK_LIMIT_MB=0

# ──────────────────────────────────────────────────────────────────────────────
# Claude Code-inspired Features
# Added in the Tinker integration update.  All have sensible defaults and are
# safe to leave commented out — Tinker works without them.
# ──────────────────────────────────────────────────────────────────────────────

# ── TINKER.md — Project instructions ──────────────────────────────────────────
# Path to a Markdown file that is injected into the Architect AI's system prompt
# on every micro loop.  Analogous to CLAUDE.md in Claude Code.  Create your own
# project-specific TINKER.md to guide the Architect's decisions and conventions.
# If the file doesn't exist, Tinker starts normally without project instructions.
TINKER_INSTRUCTIONS_PATH=./TINKER.md

# ── Human-in-the-loop confirmation gates ──────────────────────────────────────
# Comma-separated list of action names that require human approval before Tinker
# proceeds.  The orchestrator pauses and prompts you (via CLI or the Dashboard)
# to approve or deny the action.
#
# Recognised action names:
#   git_push        — before Fritz pushes to a remote git branch
#   artifact_delete — before overwriting an existing artifact file
#   macro_snapshot  — before committing an architecture snapshot to git
#
# Set to empty string (the default) to let everything through automatically.
TINKER_CONFIRM_BEFORE=
#TINKER_CONFIRM_BEFORE=git_push,artifact_delete

# How many seconds to wait for a human response before auto-approving.
# 0 = wait forever (only safe if you're actively monitoring).
# 300 = wait up to 5 minutes, then auto-approve (safe for overnight runs).
TINKER_CONFIRM_TIMEOUT=300

# Where the webui writes confirmation response files (one per pending request).
# The orchestrator polls this directory to receive Dashboard approve/deny actions.
TINKER_CONFIRM_DIR=./tinker_confirmations

# ── Pause / resume checkpointing ──────────────────────────────────────────────
# Saves the in-progress micro loop state to disk so that if Tinker is paused,
# killed, or crashes, the next run can resume where it left off without repeating
# the Architect/Critic calls.
#
# Set to false to disable (useful for testing or ephemeral runs).
TINKER_CHECKPOINT_ENABLED=true

# Path to the checkpoint JSON file.  Same directory as the state snapshot.
TINKER_CHECKPOINT_PATH=./tinker_checkpoint.json

# Where the webui writes pause/resume control signals.
TINKER_CONTROL_DIR=./tinker_control

# ── MCP (Model Context Protocol) ──────────────────────────────────────────────
# MCP lets Tinker expose its tools to external clients (e.g. Claude Code) and
# consume tools from external MCP servers (e.g. a filesystem server on the NAS).
#
# Set to true to enable.  Default: false (MCP is opt-in).
TINKER_MCP_ENABLED=false

# URL path where the MCP server is mounted on the webui FastAPI app.
# The SSE stream is at {path}/sse, messages at {path}/messages.
TINKER_MCP_SERVER_PATH=/mcp

# Name and version advertised in the MCP initialize handshake.
TINKER_MCP_SERVER_NAME=tinker
TINKER_MCP_SERVER_VERSION=1.0.0

# Comma-separated list of external MCP server SSE URLs to connect to.
# Their tools will be imported into Tinker's ToolRegistry and become available
# to the Architect AI alongside Tinker's native tools.
# Example: http://nas:9000/mcp/sse,http://desktop:9001/mcp/sse
TINKER_MCP_SERVERS=

# How long (seconds) to wait when connecting to an external MCP server on startup.
# Failures are non-fatal — a server that is offline is skipped and logged.
TINKER_MCP_CONNECT_TIMEOUT=10

# ── Grub: Model assignments per minion ─────────────────────────────────────
# Each Grub minion can use a different Ollama model.  Assign bigger models
# to complex tasks (coder, debugger) and faster models to evaluation tasks.
GRUB_CODER_MODEL=qwen2.5-coder:32b
GRUB_REVIEWER_MODEL=qwen3:7b
GRUB_TESTER_MODEL=qwen3:7b
GRUB_DEBUGGER_MODEL=qwen2.5-coder:32b
GRUB_REFACTORER_MODEL=qwen2.5-coder:7b

# Base Ollama URL for all minions (override per-minion in grub_config.json)
GRUB_OLLAMA_URL=http://localhost:11434

# ── Grub: Execution & quality ─────────────────────────────────────────────
# Execution mode: sequential | parallel | queue
GRUB_EXEC_MODE=sequential
# Reviewer score (0.0–1.0) needed to accept minion output
GRUB_QUALITY_THRESHOLD=0.75
# Max retries per minion before giving up
GRUB_MAX_ITERATIONS=5
# Output directory for generated code
GRUB_OUTPUT_DIR=./grub_output
# Whether Grub auto-commits to git
GRUB_ENABLE_GIT=false
# HTTP timeout for Ollama requests (seconds)
GRUB_REQUEST_TIMEOUT=120.0

# ── Grub: Context summarization ───────────────────────────────────────────────
# When Grub minions receive large inputs (design documents > 6000 chars, long
# stack traces), they can summarize them using a small LLM model instead of
# hard-truncating.  This preserves more information than a raw cut-off.
#
# Set to false to revert to the old hard-truncation behaviour.
GRUB_CONTEXT_SUMMARIZATION=true

# Characters above which the summarizer is triggered (default 6000).
GRUB_CONTEXT_MAX_CHARS=6000

# Target length in characters after summarization (default 3000).
GRUB_CONTEXT_TARGET_CHARS=3000

# Model to use for summarization.  Defaults to the reviewer's model (fast 7B).
# Leave empty to use each minion's own model instead.
GRUB_SUMMARIZER_MODEL=
#GRUB_SUMMARIZER_MODEL=qwen3:1.7b

# ── Trino / Presto (alternative session storage) ───────────────────────────
# Use Trino instead of DuckDB for session artifacts.  Useful when you have
# an existing data warehouse or need multi-instance artifact sharing.
# Set TINKER_SESSION_BACKEND=trino to enable (default: duckdb).
# Requires: pip install trino
TINKER_SESSION_BACKEND=duckdb
TINKER_TRINO_HOST=localhost
TINKER_TRINO_PORT=8080
TINKER_TRINO_USER=tinker
TINKER_TRINO_CATALOG=memory
TINKER_TRINO_SCHEMA=tinker

# ── Self-Improvement Engine ────────────────────────────────────────────────
# Enables Tinker to analyze its own performance and generate improvement
# tasks targeting its own codebase.  All changes are committed to a
# dedicated branch and require human review before merging.
TINKER_SELF_IMPROVE_ENABLED=false
TINKER_SELF_IMPROVE_BRANCH=tinker/self-improve

# ── OpenTelemetry Tracing (optional) ───────────────────────────────────────
# Distributed tracing via OpenTelemetry.  Requires:
#   pip install opentelemetry-api opentelemetry-sdk opentelemetry-exporter-otlp
# Exports traces to any OTel-compatible backend (Jaeger, Zipkin, Datadog, etc.)
TINKER_OTEL_ENABLED=false
TINKER_OTEL_ENDPOINT=http://localhost:4317
